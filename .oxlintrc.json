{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "node_modules/",
    ".source/",
    ".next/",
    "out/",
    "next-env.d.ts",
    "tsconfig.tsbuildinfo"
  ],
  "plugins": ["eslint", "typescript", "unicorn", "react", "nextjs"],
  "categories": {
    "correctness": "error",
    "perf": "warn"
  },
  "env": {
    "builtin": true
  }
}
