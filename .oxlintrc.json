{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["node_modules/", ".source/", ".next/", "out/"],
  "plugins": ["eslint", "typescript", "unicorn", "react", "nextjs"],
  "categories": {
    "correctness": "error",
    "perf": "warn"
  },
  "env": {
    "builtin": true
  },
  "settings": {
    "react": {
      "version": "19.2.7"
    }
  }
}
