  "dependencies": {
    "@fumadocs/base-ui": "^16.11.1",
    "@orama/orama": "^3.1.18",
    "@orama/stopwords": "^3.1.18",
    "@orama/tokenizers": "^3.1.18",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.1",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.70.0",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "packageManager": {
